# ========================================
# pay-common 环境变量配置
# 复制此文件为 .env 并填入实际值
# key 与授权类型 Ext 字段对齐
# ========================================

# ---------- 签名模式切换 ----------
# gateway: 回调由集成中心解密，转发明文（默认，正式上线模式）
# sdk: 回调自己验签 + AES-GCM 解密
# 注意：两种模式下，主动请求（下单/退款/转账）都走 SDK 自签名直连微信
signMode=gateway

# ---------- 微信支付基础配置 ----------
# 小程序/公众号/移动应用 AppID（注意不同支付方式对应不同类型的 AppID）
# JSAPI/H5 → 公众号 AppID | 小程序 → 小程序 AppID | APP → 移动应用 AppID
appId=
# 服务号 AppID（同一个商户号绑定的服务号，用于 Web 端 JSAPI 支付）
# 调用时传 useServiceAccount: true 即可使用该 AppID
service_app_id=
# 支付商户号
merchantId=
# 商户 API 证书序列号
merchantSerialNumber=
# API V3 密钥（32 字节，用于回调解密）
apiV3Key=

# ---------- 凭证配置（两种模式都需要）----------
# 商户 API 证书私钥（PEM 格式字符串，用于请求签名）
# 注意：不要提交到 git，不要硬编码在代码中
privateKey=
# 微信支付公钥（PEM 格式字符串，用于验签）
wxPayPublicKey=
# 微信支付公钥 ID（标识使用哪个公钥）
wxPayPublicKeyId=

# ---------- 回调通知 URL ----------
# 必须以 https:// 开头，不能用 localhost/127.0.0.1，不能带参数
# SDK 模式：填云函数/云托管自己的公网 URL
# 网关模式：填集成中心分配的回调域名
notifyURLPayURL=
notifyURLRefundsURL=
# 商家转账回调（可选，不设则转账不接收回调通知。Ext 字段无此项，pay-common 扩展）
transferNotifyUrl=

# ---------- 服务端口（本地开发/云托管用）----------
PORT=3000

# ---------- CORS 跨域（可选）----------
# 仅当前端页面与本服务不同源时配置（如 H5 页面直接调用）
# 多个域名逗号分隔，例：https://a.com,https://b.com
# 不填则不开放跨域
corsAllowOrigin=
