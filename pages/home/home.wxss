.home {
  min-height: 100vh;
  padding: 48rpx 36rpx;
  background: linear-gradient(180deg, #F0F7FF 0%, #E8F0FE 100%);
}

.hero {
  padding: 80rpx 24rpx 48rpx;
  text-align: center;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.hero-sub {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.tips {
  margin-top: 32rpx;
  padding: 36rpx 32rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1677FF;
  margin-bottom: 20rpx;
}

.tip-row {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
}

.brand-foot {
  margin-top: 120rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 4rpx;
}

.mode-section {
  margin-top: 64rpx;
}

.mode-title {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.mode-row {
  display: flex;
  gap: 20rpx;
}

.mode-option {
  flex: 1;
  padding: 28rpx 20rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  text-align: center;
  box-sizing: border-box;
}

.mode-option-active {
  border-color: #1677FF;
  background: #F0F7FF;
}

.mode-option-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.mode-option-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}
