.home {
  min-height: 100vh;
  padding: 48rpx 36rpx;
  background: linear-gradient(180deg, #FFF8F0 0%, #F5EFE6 100%);
}

.hero {
  padding: 80rpx 24rpx 48rpx;
  text-align: center;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #2A1810;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.hero-sub {
  font-size: 28rpx;
  color: #6B5544;
  line-height: 1.6;
}

.tips {
  margin-top: 32rpx;
  padding: 36rpx 32rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5C3A21;
  margin-bottom: 20rpx;
}

.tip-row {
  font-size: 28rpx;
  color: #6B5544;
  line-height: 2;
}

.brand-foot {
  margin-top: 120rpx;
  text-align: center;
  font-size: 24rpx;
  color: #A89180;
  letter-spacing: 4rpx;
}

.preview-btns {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
}

.preview-btn {
  padding: 22rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8B5E3C 0%, #5C3A21 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.btn-hover {
  opacity: 0.85;
}

.mode-bar {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.mode-label {
  font-size: 24rpx;
  color: #A89180;
}

.mode-switch {
  position: relative;
  width: 120rpx;
  height: 48rpx;
  background: #E8E0D8;
  border-radius: 48rpx;
  cursor: pointer;
  display: flex;
  align-items: center;
  padding: 0 12rpx;
}

.mode-switch.is-formal {
  background: #5C3A21;
}

.mode-thumb {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.is-formal .mode-thumb {
  left: 76rpx;
}

.mode-text-preview {
  font-size: 20rpx;
  color: #5C3A21;
  font-weight: 500;
  margin-right: auto;
}

.is-formal .mode-text-preview {
  color: rgba(255,255,255,0.5);
}

.mode-text-formal {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
  margin-left: auto;
}

.is-formal .mode-text-formal {
  color: #FFFFFF;
}
