<view class="home">
  <view class="hero">
    <view class="hero-title">AI Skill 小程序</view>
    <view class="hero-sub">在对话框说出你的需求，AI 为你智能服务</view>
  </view>

  <view class="tips card">
    <view class="tips-title">你可以这样对我说</view>
    <view class="tip-row">· 帮我点个外卖</view>
    <view class="tip-row">· 查询医院挂号信息</view>
    <view class="tip-row">· 帮我叫一辆车</view>
    <view class="tip-row">· 记录一下今天的喝水量</view>
  </view>

  <view class="brand-foot">— AI 驱动的小程序智能体验 —</view>

  <view class="mode-section">
    <view class="mode-title">数据来源</view>
    <view class="mode-row">
      <view class="mode-option {{previewMode ? 'mode-option-active' : ''}}" bind:tap="onSetPreview">
        <text class="mode-option-label">本地数据</text>
        <text class="mode-option-desc">使用内置 seed 数据，无需部署</text>
      </view>
      <view class="mode-option {{!previewMode ? 'mode-option-active' : ''}}" bind:tap="onSetFormal">
        <text class="mode-option-label">正式数据</text>
        <text class="mode-option-desc">调用云函数，连接数据库</text>
      </view>
    </view>
  </view>
</view>
