/* skills/bill-skill/components/history-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.history-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  margin: 16rpx 0;
}

@media (prefers-color-scheme: dark) {
  .history-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
}

/* 头部 */
.header {
  padding: 32rpx 32rpx 24rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}
.header-count {
  font-size: 24rpx;
  color: #6E6E73;
}
.header-amount {
  color: #12B76A;
  font-weight: 600;
}
.header-empty {
  font-size: 28rpx;
  color: #8E8E93;
  padding: 48rpx 0;
  text-align: center;
}
@media (prefers-color-scheme: dark) {
  .header-title {
    color: #FFFFFF;
  }
  .header-count {
    color: rgba(255, 255, 255, 0.68);
  }
  .header-empty {
    color: rgba(255, 255, 255, 0.48);
  }
}

/* 列表 */
.history-list {
  padding: 0 0 8rpx;
}
.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
}
@media (prefers-color-scheme: dark) {
  .history-item {
    border-top-color: rgba(255, 255, 255, 0.08);
  }
}

/* 图标 */
.history-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F0FFF5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.history-icon {
  width: 36rpx;
  height: 36rpx;
}
@media (prefers-color-scheme: dark) {
  .history-icon-wrap {
    background: rgba(18, 183, 106, 0.10);
  }
}

/* 信息 */
.history-info {
  flex: 1;
  min-width: 0;
}
.history-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  margin-bottom: 4rpx;
}
.history-provider {
  font-size: 24rpx;
  color: #6E6E73;
  margin-bottom: 4rpx;
}
.history-meta {
  font-size: 20rpx;
  color: #8E8E93;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.history-divider {
  color: rgba(0, 0, 0, 0.15);
}
@media (prefers-color-scheme: dark) {
  .history-type {
    color: #FFFFFF;
  }
  .history-provider {
    color: rgba(255, 255, 255, 0.68);
  }
  .history-meta {
    color: rgba(255, 255, 255, 0.48);
  }
  .history-divider {
    color: rgba(255, 255, 255, 0.15);
  }
}

/* 金额 */
.history-amount-wrap {
  text-align: right;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.history-amount {
  font-size: 28rpx;
  font-weight: 500;
  color: #F04438;
}
.history-paymethod {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}
@media (prefers-color-scheme: dark) {
  .history-amount {
    color: #F04438;
  }
  .history-paymethod {
    color: rgba(255, 255, 255, 0.48);
  }
}
