/* skills/bill-skill/components/bill-list-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.bill-list-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  margin: 16rpx 0;
}

@media (prefers-color-scheme: dark) {
  .bill-list-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
}

/* 头部 */
.header {
  padding: 32rpx 32rpx 24rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}
@media (prefers-color-scheme: dark) {
  .header-title {
    color: #FFFFFF;
  }
}
.header-count {
  font-size: 24rpx;
  color: #6E6E73;
}
.header-amount {
  color: #12B76A;
  font-weight: 600;
}
.header-empty {
  font-size: 28rpx;
  color: #8E8E93;
  padding: 48rpx 0;
  text-align: center;
}
@media (prefers-color-scheme: dark) {
  .header-count {
    color: rgba(255, 255, 255, 0.68);
  }
  .header-empty {
    color: rgba(255, 255, 255, 0.48);
  }
}

/* 逾期提醒 */
.overdue-banner {
  background: #FFF8F0;
  margin: 0 32rpx 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.overdue-icon {
  font-size: 24rpx;
}
.overdue-text {
  font-size: 24rpx;
  color: #E65100;
  flex: 1;
}
@media (prefers-color-scheme: dark) {
  .overdue-banner {
    background: rgba(255, 159, 10, 0.12);
  }
  .overdue-text {
    color: #FF9F0A;
  }
}

/* 账单列表 */
.bill-list {
  padding: 0 0 8rpx;
}
.bill-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  position: relative;
}
.bill-item-active {
  background: #F0FFF5;
}
@media (prefers-color-scheme: dark) {
  .bill-item {
    border-top-color: rgba(255, 255, 255, 0.08);
  }
  .bill-item-active {
    background: rgba(18, 183, 106, 0.10);
  }
}

/* 图标 */
.bill-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F0FFF5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.bill-icon {
  width: 36rpx;
  height: 36rpx;
}
@media (prefers-color-scheme: dark) {
  .bill-icon-wrap {
    background: rgba(18, 183, 106, 0.10);
  }
}

/* 信息区 */
.bill-info {
  flex: 1;
  min-width: 0;
}
.bill-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  margin-bottom: 4rpx;
}
.bill-provider {
  font-size: 24rpx;
  color: #6E6E73;
  margin-bottom: 4rpx;
}
.bill-meta {
  font-size: 20rpx;
  color: #8E8E93;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.bill-divider {
  color: rgba(0, 0, 0, 0.15);
}
.bill-due.overdue {
  color: #E65100;
}
@media (prefers-color-scheme: dark) {
  .bill-type {
    color: #FFFFFF;
  }
  .bill-provider {
    color: rgba(255, 255, 255, 0.68);
  }
  .bill-meta {
    color: rgba(255, 255, 255, 0.48);
  }
  .bill-divider {
    color: rgba(255, 255, 255, 0.15);
  }
  .bill-due.overdue {
    color: #FF9F0A;
  }
}

/* 金额区 */
.bill-amount-wrap {
  text-align: right;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.bill-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.bill-amount-label {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}
@media (prefers-color-scheme: dark) {
  .bill-amount {
    color: #FFFFFF;
  }
  .bill-amount-label {
    color: rgba(255, 255, 255, 0.48);
  }
}
