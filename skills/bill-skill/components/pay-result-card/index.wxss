/* skills/bill-skill/components/pay-result-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.pay-result-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  padding: 32rpx;
  margin: 16rpx 0;
}

@media (prefers-color-scheme: dark) {
  .pay-result-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
}

/* 状态 */
.result-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}
.status-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.status-icon.success {
  background: #F0FFF5;
  color: #12B76A;
}
.status-icon.fail {
  background: #FFF0F0;
  color: #F04438;
}
.status-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}
@media (prefers-color-scheme: dark) {
  .status-icon.success {
    background: rgba(18, 183, 106, 0.10);
  }
  .status-text {
    color: #FFFFFF;
  }
}

/* 金额 */
.result-amount {
  text-align: center;
  font-size: 72rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}
.result-amount-label {
  text-align: center;
  font-size: 28rpx;
  color: #6E6E73;
  margin-bottom: 32rpx;
}
@media (prefers-color-scheme: dark) {
  .result-amount {
    color: #FFFFFF;
  }
  .result-amount-label {
    color: rgba(255, 255, 255, 0.68);
  }
}

/* 详情 */
.result-detail {
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}
.detail-row-last {
  border-bottom: none;
}
.detail-label {
  font-size: 28rpx;
  color: #6E6E73;
}
.detail-value {
  font-size: 28rpx;
  color: #1D1D1F;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}
@media (prefers-color-scheme: dark) {
  .result-detail {
    background: rgba(255, 255, 255, 0.05);
  }
  .detail-row {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
  .detail-label {
    color: rgba(255, 255, 255, 0.68);
  }
  .detail-value {
    color: #FFFFFF;
  }
}

/* 按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-primary {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}
.btn-primary-hover {
  opacity: 0.85;
}
.btn-outline {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #12B76A;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: 1px solid #12B76A;
}
.btn-outline-hover {
  background: #F0FFF5;
}
@media (prefers-color-scheme: dark) {
  .btn-primary {
    background: #F2F2F7;
    color: #1D1D1F;
  }
  .btn-outline {
    color: #12B76A;
    border-color: #12B76A;
  }
  .btn-outline-hover {
    background: rgba(18, 183, 106, 0.10);
  }
}
