{
  "version": "2.0",
  "functions": [
    {
      "name": "bill-skill-handler",
      "type": "event",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 256,
      "installDependency": true,
      "dir": "cloudfunctions/bill-skill-handler",
      "ignore": ["node_modules", ".git"]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "bill_records",
        "description": "缴费记录",
        "indexes": [
          { "field": "openid", "unique": false }
        ]
      }
    ]
  }
}
