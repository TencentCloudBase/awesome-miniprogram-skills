/* skills/todolist-skill/components/todo-list-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.td-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.td-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.td-head-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  min-width: 0;
}

.td-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.td-count {
  font-size: 24rpx;
  color: #6E6E73;
}

.td-add {
  flex-shrink: 0;
  width: 66rpx;
  height: 66rpx;
  border-radius: 999rpx;
  background: #F5F5F7;
  color: #2C2C2E;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 64rpx;
  text-align: center;
}

.td-add-hover {
  opacity: 0.88;
}

.td-empty {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  background: #F5F5F7;
}

.td-empty-title {
  font-size: 28rpx;
  color: #1D1D1F;
}

.td-empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6E6E73;
  line-height: 1.5;
}

.td-item {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  background: #F5F5F7;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
}

.td-item.is-done {
  opacity: 0.72;
}

.td-check {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border: 1px solid #E5E5EA;
  border-radius: 999rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.td-check.is-done {
  background: #2C2C2E;
  border-color: #2C2C2E;
}

.td-check-inner {
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 1;
}

.td-check-hover,
.td-delete-hover {
  opacity: 0.88;
}

.td-main {
  flex: 1;
  min-width: 0;
}

.td-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-item-title.is-done {
  color: #6E6E73;
  opacity: 0.6;
}

.td-item-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6E6E73;
}

.td-delete {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #FFF0F0;
  color: #F04438;
  text-align: center;
  line-height: 58rpx;
  font-size: 40rpx;
  font-weight: 400;
}

@media (prefers-color-scheme: dark) {
  .td-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .td-title, .td-item-title { color: #FFFFFF; }
  .td-count, .td-empty-desc, .td-item-meta, .td-item-title.is-done { color: rgba(255,255,255,0.68); }
  .td-empty, .td-item { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); }
  .td-add { color: #F2F2F7; background: rgba(255,255,255,0.08); }
  .td-check { background: #1C1C1E; border-color: rgba(255,255,255,0.12); }
  .td-check.is-done { background: #F2F2F7; border-color: #F2F2F7; }
  .td-delete { color: #F04438; background: rgba(240, 68, 56, 0.12); }
}
