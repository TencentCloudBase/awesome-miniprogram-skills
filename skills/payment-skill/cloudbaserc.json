{
  "version": "2.0",
  "functions": [
    {
      "name": "pay-common",
      "type": "http",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 256,
      "installDependency": true,
      "dir": "cloudfunctions/pay-common",
      "envVariables": {
        "signMode": "{{env.SIGN_MODE}}",
        "appId": "{{env.WX_APP_ID}}",
        "service_app_id": "{{env.SERVICE_APP_ID}}",
        "merchantId": "{{env.MCH_ID}}",
        "merchantSerialNumber": "{{env.MCH_SERIAL_NO}}",
        "apiV3Key": "{{env.API_V3_KEY}}",
        "privateKey": "{{env.PRIVATE_KEY}}",
        "wxPayPublicKey": "{{env.WX_PAY_PUBLIC_KEY}}",
        "wxPayPublicKeyId": "{{env.WX_PAY_PUBLIC_KEY_ID}}",
        "notifyURLPayURL": "{{env.NOTIFY_PAY_URL}}",
        "notifyURLRefundsURL": "{{env.NOTIFY_REFUNDS_URL}}",
        "transferNotifyUrl": "{{env.NOTIFY_TRANSFER_URL}}",
        "corsAllowOrigin": "{{env.CORS_ALLOW_ORIGIN}}"
      },
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "payment_records",
        "description": "支付记录",
        "indexes": [
          {
            "field": "openid",
            "unique": false
          },
          {
            "field": "orderId",
            "unique": false
          }
        ],
        "aclTag": "PRIVATE"
      }
    ]
  }
}
