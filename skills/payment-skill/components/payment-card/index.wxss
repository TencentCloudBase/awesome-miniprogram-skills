/* ratio=4:1 支付状态结果卡，轻量单行信息 + 状态图标
 * 色源：app.wxss page (primary-brand: #8B5E3C, bg-cream: #FFF8F0)
 *       暗黑：源项目无 darkmode → 浅色降明度
 */
.pc-wrapper {
  padding: 3.2vw;
  background: #FFFFFF;
  border-radius: 1.07vw;
}

.pc-idle, .pc-paying, .pc-success, .pc-fail {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2.13vw;
}

.pc-icon {
  font-size: 9.6vw;
  line-height: 1;
}

.pc-text {
  font-size: 4.53vw;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
}

.pc-amount {
  font-size: 6.4vw;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
}

.pc-time {
  font-size: 3.2vw;
  color: rgba(0, 0, 0, 0.45);
}

.pc-error {
  font-size: 3.2vw;
  color: #EE0A24;
}

.pc-btn {
  margin-top: 2.13vw;
  width: 48vw;
  height: 10.67vw;
  line-height: 10.67vw;
  text-align: center;
  background: #8B5E3C;
  color: #FFFFFF;
  font-size: 4vw;
  font-weight: 500;
  border-radius: 1.07vw;
  border: none;
}

.pc-btn-hover {
  opacity: 0.8;
}

@media (prefers-color-scheme: dark) {
  .pc-wrapper { background: #2A1E16; }
  .pc-text, .pc-amount { color: rgba(255, 255, 255, 0.9); }
  .pc-time { color: rgba(255, 255, 255, 0.45); }
}
