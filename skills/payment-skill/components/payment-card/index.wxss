.pc-wrapper {
  padding: 32rpx;
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.pc-paying,
.pc-success,
.pc-fail {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.pc-icon-indicator {
  display: block;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.pc-icon-spinning {
  border: 6rpx solid #E5E5EA;
  border-top-color: #2C2C2E;
  animation: pc-spin 0.8s linear infinite;
}

.pc-icon-success {
  position: relative;
  background: #12B76A;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pc-icon-success-inner {
  width: 28rpx;
  height: 14rpx;
  border-left: 4rpx solid #FFFFFF;
  border-bottom: 4rpx solid #FFFFFF;
  transform: rotate(-45deg);
  margin-bottom: 4rpx;
}

.pc-icon-fail {
  position: relative;
  background: #F04438;
}

.pc-icon-fail-line {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.pc-icon-fail-line-a {
  transform: translate(-50%, -50%) rotate(45deg);
}

.pc-icon-fail-line-b {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.pc-text {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.pc-amount {
  font-size: 56rpx;
  line-height: 72rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.pc-time {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #6E6E73;
}

.pc-error {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #F04438;
  text-align: center;
}

.pc-btn {
  margin-top: 12rpx;
  min-width: 192rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 999rpx;
  border: none;
}

.pc-btn-hover {
  opacity: 0.86;
}

@keyframes pc-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@media (prefers-color-scheme: dark) {
  .pc-wrapper {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .pc-text,
  .pc-amount {
    color: #FFFFFF;
  }

  .pc-time {
    color: rgba(255, 255, 255, 0.68);
  }

  .pc-icon-spinning {
    border-color: rgba(255, 255, 255, 0.12);
    border-top-color: #F2F2F7;
  }

  .pc-btn {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
