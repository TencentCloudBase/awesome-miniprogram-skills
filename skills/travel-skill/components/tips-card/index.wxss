/* WeCard Design System — Travel Tips Card */
.tc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.tc-header {
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}
.tc-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.tc-subtitle {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}
.tc-empty {
  padding: 64rpx 32rpx;
  text-align: center;
}
.tc-empty-text {
  font-size: 28rpx;
  color: #6E6E73;
}
.tc-list {
  padding: 8rpx 0;
}
.tc-item {
  padding: 24rpx 32rpx;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}
.tc-item-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.tc-item-icon {
  font-size: 48rpx;
  width: 64rpx;
  text-align: center;
  flex-shrink: 0;
}
.tc-item-info {
  flex: 1;
  min-width: 0;
}
.tc-item-category {
  font-size: 24rpx;
  color: #D4813D;
  font-weight: 500;
}
.tc-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  margin-top: 4rpx;
}
.tc-item-arrow {
  font-size: 24rpx;
  color: #8E8E93;
  flex-shrink: 0;
}
.tc-item-body {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(212, 129, 61, 0.06);
  border-radius: 16rpx;
}
.tc-item-content {
  font-size: 28rpx;
  color: #1D1D1F;
  line-height: 1.6;
}
.tc-footer {
  padding: 24rpx 32rpx;
  border-top: 1px solid #E5E5EA;
  background: rgba(212, 129, 61, 0.04);
}
.tc-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}
.tc-btn-hover {
  opacity: 0.85;
}

@media (prefers-color-scheme: dark) {
  .tc-card {
    background: #1C1C1E;
    border-color: rgba(255,255,255,0.08);
    box-shadow: none;
  }
  .tc-header { border-color: rgba(255,255,255,0.08); }
  .tc-title { color: #FFFFFF; }
  .tc-subtitle { color: rgba(255,255,255,0.68); }
  .tc-empty-text { color: rgba(255,255,255,0.68); }
  .tc-item { border-color: rgba(255,255,255,0.08); }
  .tc-item-title { color: #FFFFFF; }
  .tc-item-category { color: #F5A97F; }
  .tc-item-arrow { color: rgba(255,255,255,0.48); }
  .tc-item-body { background: rgba(255,255,255,0.06); }
  .tc-item-content { color: rgba(255,255,255,0.80); }
  .tc-footer {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
  }
  .tc-btn { background: #F2F2F7; color: #1D1D1F; }
}
