/* WeCard Design System — Trip Plan Card */
.tp-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.tp-empty {
  padding: 96rpx 32rpx;
  text-align: center;
}
.tp-empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.tp-empty-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6E6E73;
}
.tp-hero {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}
.tp-cover {
  width: 100%;
  height: 100%;
}
.tp-hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(transparent, rgba(28, 28, 30, 0.85));
}
.tp-hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.tp-hero-en {
  font-size: 24rpx;
  color: rgba(255,255,255,0.70);
}
.tp-hero-rating {
  font-size: 24rpx;
  color: #FF9F0A;
  margin-top: 8rpx;
}
.tp-hero-season {
  font-size: 24rpx;
  color: rgba(255,255,255,0.80);
  margin-top: 4rpx;
}
.tp-desc {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #6E6E73;
  line-height: 1.5;
  background: rgba(212, 129, 61, 0.04);
  border-bottom: 1px solid #E5E5EA;
}
.tp-tabs {
  display: flex;
  border-bottom: 1px solid #E5E5EA;
}
.tp-tab {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #6E6E73;
  position: relative;
}
.tp-tab.is-active {
  color: #D4813D;
  font-weight: 600;
  position: relative;
}
.tp-tab-active-bar {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #D4813D;
  border-radius: 4rpx 4rpx 0 0;
}
.tp-section {
  padding: 16rpx 32rpx 32rpx;
}
.tp-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}
.tp-item-icon {
  font-size: 48rpx;
  width: 72rpx;
  text-align: center;
  flex-shrink: 0;
}
.tp-item-body {
  flex: 1;
  min-width: 0;
}
.tp-item-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.tp-star-tag {
  font-size: 20rpx;
  color: #D4813D;
  background: rgba(212, 129, 61, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}
.tp-item-route,
.tp-item-carrier {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}
.tp-item-stars {
  font-size: 24rpx;
  color: #FF9F0A;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.tp-hotel-rating {
  font-size: 24rpx;
  color: #6E6E73;
}
.tp-item-features {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}
.tp-feature-tag {
  font-size: 20rpx;
  color: #D4813D;
  background: rgba(212, 129, 61, 0.08);
  padding: 2rpx 16rpx;
  border-radius: 999rpx;
}
.tp-item-district {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}
.tp-item-right {
  text-align: right;
  flex-shrink: 0;
}
.tp-item-duration {
  font-size: 24rpx;
  font-weight: 500;
  color: #D4813D;
}
.tp-item-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #F04438;
}
.tp-item-unit {
  font-size: 20rpx;
  color: #8E8E93;
}
.tp-footer-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1px solid #E5E5EA;
  background: rgba(212, 129, 61, 0.04);
}
.tp-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 999rpx;
}
.tp-btn-weather {
  color: #FFFFFF;
  background: #2C2C2E;
}
.tp-btn-back {
  color: #D4813D;
  background: #FFFFFF;
  border: 1px solid rgba(212, 129, 61, 0.30);
}
.tp-btn-hover {
  opacity: 0.85;
}

@media (prefers-color-scheme: dark) {
  .tp-card {
    background: #1C1C1E;
    border-color: rgba(255,255,255,0.08);
    box-shadow: none;
  }
  .tp-empty-title { color: #FFFFFF; }
  .tp-empty-desc { color: rgba(255,255,255,0.68); }
  .tp-desc {
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.68);
    border-color: rgba(255,255,255,0.08);
  }
  .tp-tabs { border-color: rgba(255,255,255,0.08); }
  .tp-tab { color: rgba(255,255,255,0.68); }
  .tp-tab.is-active { color: #F5A97F; }
  .tp-item { border-color: rgba(255,255,255,0.08); }
  .tp-item-label { color: #FFFFFF; }
  .tp-item-route,
  .tp-item-carrier { color: rgba(255,255,255,0.68); }
  .tp-item-district { color: rgba(255,255,255,0.48); }
  .tp-hotel-rating { color: rgba(255,255,255,0.68); }
  .tp-star-tag { background: rgba(255,255,255,0.08); color: #F5A97F; }
  .tp-feature-tag { background: rgba(255,255,255,0.08); color: #F5A97F; }
  .tp-item-unit { color: rgba(255,255,255,0.48); }
  .tp-footer-actions {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
  }
  .tp-btn-back {
    background: #1C1C1E;
    color: #F5A97F;
    border-color: rgba(245,169,127,0.30);
  }
}
