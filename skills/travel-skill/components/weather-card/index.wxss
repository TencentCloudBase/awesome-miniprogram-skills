/* WeCard Design System — Weather Card */
.wc-card {
  background: linear-gradient(135deg, #D4813D 0%, #B86A38 100%);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}
.wc-empty {
  text-align: center;
  padding: 24rpx;
}
.wc-empty-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.70);
}
.wc-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}
.wc-dest {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.wc-icon {
  font-size: 56rpx;
}
.wc-temp {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -2rpx;
}
.wc-condition {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}
.wc-detail {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.70);
}
.wc-detail-item {
  background: rgba(255,255,255,0.15);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.wc-suggestion {
  width: 100%;
  font-size: 24rpx;
  color: rgba(255,255,255,0.80);
  margin-top: 8rpx;
}

@media (prefers-color-scheme: dark) {
  .wc-card {
    background: linear-gradient(135deg, #B86A38 0%, #8C532C 100%);
  }
}
