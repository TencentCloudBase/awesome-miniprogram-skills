.dl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.dl-title {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.dl-keyword {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.08);
  flex-shrink: 0;
}

.dl-scroll {
  max-height: 520px;
}

.dl-empty {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F7F7F8;
  border: 1px solid #E5E5EA;
}

.dl-empty-title {
  font-size: 32rpx;
  line-height: 44rpx;
  color: #1D1D1F;
}

.dl-empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #6E6E73;
}

.dl-item {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
}

.dl-cover {
  width: 168rpx;
  height: 168rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #E5E5EA;
}

.dl-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dl-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.dl-name {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.dl-en-name {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #8E8E93;
}

.dl-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: auto;
}

.dl-star,
.dl-score {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #FF9F0A;
}

.dl-score {
  font-weight: 500;
}

.dl-desc {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #6E6E73;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.dl-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dl-season {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dl-label,
.dl-season-desc {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #8E8E93;
}

.dl-value {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #007AFF;
}

.dl-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.dl-tag {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  color: #6E6E73;
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.dl-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.dl-btn {
  min-width: 168rpx;
  height: 80rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.dl-btn-plan {
  color: #FFFFFF;
  background: #2C2C2E;
}

.dl-btn-weather {
  color: #1D1D1F;
  background: #F2F2F7;
  border: 1px solid #F2F2F7;
}

.dl-btn-hover {
  opacity: 0.86;
}

@media (prefers-color-scheme: dark) {
  .dl-card,
  .dl-item {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .dl-title,
  .dl-empty-title,
  .dl-name {
    color: #FFFFFF;
  }

  .dl-keyword {
    background: rgba(10, 132, 255, 0.16);
    color: #5AC8FA;
  }

  .dl-empty {
    background: #2C2C2E;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .dl-empty-desc,
  .dl-en-name,
  .dl-desc,
  .dl-label,
  .dl-season-desc,
  .dl-tag {
    color: rgba(255, 255, 255, 0.68);
  }

  .dl-cover {
    background: #2C2C2E;
  }

  .dl-value {
    color: #5AC8FA;
  }

  .dl-tag,
  .dl-btn-weather {
    background: #2C2C2E;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .dl-btn-plan {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
