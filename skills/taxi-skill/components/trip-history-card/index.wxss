/* WeCard Design System - Trip History Card
 * Success: #12B76A, Danger: #F04438
 */
.th-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.th-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 20rpx;
}

.th-empty {
  text-align: center;
  padding: 48rpx 24rpx;
}

.th-empty-icon {
  margin-bottom: 16rpx;
}

.th-list-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto;
  background: #8E8E93;
  border-radius: 16rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.th-list-icon-text {
  font-size: 60rpx;
  color: white;
  line-height: 1;
}

.th-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.th-empty-desc {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 8rpx;
}

.th-item {
  padding: 20rpx 0;
  border-top: 2rpx solid rgba(0,0,0,0.06);
}
.th-item--first {
  border-top: none;
}

.th-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.th-route-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.th-origin {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  display: inline;
}

.th-arrow {
  font-size: 24rpx;
  color: #8E8E93;
  margin: 0 8rpx;
  display: inline;
}

.th-destination {
  font-size: 28rpx;
  color: #6E6E73;
  display: inline;
}

.th-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.th-item-bottom {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.th-meta {
  font-size: 24rpx;
  color: #6E6E73;
}

.th-meta-status {
  margin-left: auto;
  font-weight: 500;
}
.th-meta-status.completed { color: #12B76A; }
.th-meta-status.cancelled { color: #F04438; }

@media (prefers-color-scheme: dark) {
  .th-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .th-title, .th-origin, .th-price, .th-empty-title { color: #FFFFFF; }
  .th-destination { color: rgba(255,255,255,0.68); }
  .th-arrow { color: rgba(255,255,255,0.4); }
  .th-meta { color: rgba(255,255,255,0.68); }
  .th-item { border-color: rgba(255,255,255,0.08); }
  .th-item--first { border-color: transparent; }
  .th-list-icon { background: rgba(255,255,255,0.2); }
}
