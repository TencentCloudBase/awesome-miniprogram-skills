.te-car-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.te-car-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
}

.te-car-desc {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}

.te-car-meta {
  text-align: right;
  flex-shrink: 0;
}

.te-car-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.te-car-detail {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}

.te-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}

.te-btn-hover { opacity: 0.85; }

@media (prefers-color-scheme: dark) {
  .te-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .te-place, .te-car-name, .te-car-price, .te-empty-title { color: #FFFFFF; }
  .te-place-dest, .te-car-desc, .te-car-detail, .te-empty-desc { color: rgba(255,255,255,0.68); }
  .te-line { background: rgba(255,255,255,0.12); }
  .te-car-item { background: rgba(255,255,255,0.08); }
  .te-empty { background: rgba(255,255,255,0.08); }
  .te-btn { background: #F2F2F7; color: #1D1D1F; }
}
