/* WeCard Design System - Trip Estimate Card
 * 品牌点缀：#D4813D（≤5% 面积）
 * 危险色：#F04438
 */
.te-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.te-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.te-route {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.te-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.te-dot-origin { background: #D4813D; }
.te-dot-dest { background: #F04438; }

.te-line {
  flex: 1;
  width: 2rpx;
  min-height: 48rpx;
  background: rgba(0,0,0,0.1);
}

.te-places {
  flex: 1;
  min-width: 0;
}

.te-place {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.te-place-dest {
  margin-top: 16rpx;
  color: #6E6E73;
}

.te-arrow {
  font-size: 24rpx;
  color: #8E8E93;
  margin: 0 8rpx;
}

.te-empty {
  padding: 48rpx 24rpx;
  text-align: center;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.te-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.te-empty-desc {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 8rpx;
}

.te-car-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.te-car-item.is-selected {
  border: 2rpx solid #D4813D;
}

.te-car-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.te-car-svg-express, .te-car-svg-premium, .te-car-svg-economy {
  width: 48rpx;
  height: 48rpx;
  background: white;
  mask-size: contain;
  mask-repeat: no-repeat;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
}

