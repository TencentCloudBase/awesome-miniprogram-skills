{
  "version": "2.0",
  "functions": [
    {
      "name": "taxi-skill-handler",
      "type": "event",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 256,
      "installDependency": true,
      "dir": "cloudfunctions/taxi-skill-handler",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "trips",
        "description": "出行行程集合",
        "indexes": [
          {
            "field": "openid",
            "unique": false
          }
        ]
      }
    ]
  }
}