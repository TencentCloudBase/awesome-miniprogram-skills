/* WeCard 设计系统重构 - #007AFF 蓝色强调 */
.sl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.sl-header {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.sl-hospital {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.sl-dept {
  font-size: 28rpx;
  color: #6E6E73;
}
.sl-empty {
  padding: 32rpx;
  background: #F0F8FF;
  border: 1px solid #B3D9FF;
  border-radius: 16rpx;
}
.sl-empty-title {
  font-size: 32rpx;
  color: #1D1D1F;
}
.sl-empty-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6E6E73;
}
.sl-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #F0F8FF;
  border: 1px solid #D0E8FF;
  border-radius: 16rpx;
  margin-top: 16rpx;
}
.sl-item-first {
  margin-top: 0;
}
.sl-item-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 144rpx;
  flex-shrink: 0;
}
.sl-date {
  font-size: 28rpx;
  color: #6E6E73;
}
.sl-time {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-top: 4rpx;
}
.sl-item-center {
  flex: 1;
  min-width: 0;
}
.sl-doctor {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D1D1F;
}
.sl-title {
  font-size: 28rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}
.sl-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}
.sl-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #007AFF;
}
.sl-remain {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
}
.sl-remain.is-low {
  color: #F04438;
  font-weight: 500;
}
.sl-btn {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #007AFF;
  border-radius: 999rpx;
  text-align: center;
  min-width: 104rpx;
}
.sl-btn-hover {
  opacity: 0.85;
}
@media (prefers-color-scheme: dark) {
  .sl-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
  .sl-hospital { color: #FFFFFF; }
  .sl-dept { color: #8E8E93; }
  .sl-empty { background: #1C1C1E; border-color: #3A3A3C; }
  .sl-empty-title { color: #FFFFFF; }
  .sl-empty-desc { color: #8E8E93; }
  .sl-item {
    background: #2C2C2E;
    border-color: #3A3A3C;
  }
  .sl-date { color: #8E8E93; }
  .sl-time { color: #FFFFFF; }
  .sl-doctor { color: #FFFFFF; }
  .sl-title { color: #8E8E93; }
  .sl-price { color: #64B5F6; }
  .sl-remain { color: #8E8E93; }
  .sl-remain.is-low { color: #FF453A; }
  .sl-btn { background: #007AFF; }
}
