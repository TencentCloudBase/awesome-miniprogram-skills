/* WeCard 设计系统重构 - #007AFF 蓝色强调 */
.hl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.hl-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 24rpx;
}
.hl-empty {
  padding: 32rpx;
  background: #F0F8FF;
  border: 1px solid #B3D9FF;
  border-radius: 16rpx;
}
.hl-empty-title {
  font-size: 32rpx;
  color: #1D1D1F;
}
.hl-empty-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6E6E73;
}
.hl-hospital {
  margin-top: 24rpx;
  padding: 32rpx;
  background: #F0F8FF;
  border: 1px solid #D0E8FF;
  border-radius: 16rpx;
}
.hl-hospital-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.hl-hospital-left {
  flex: 1;
  min-width: 0;
}
.hl-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.hl-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hl-level {
  font-size: 24rpx;
  color: #FFFFFF;
  background: #007AFF;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.hl-rating {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #6E6E73;
}
.hl-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.hl-tag {
  font-size: 24rpx;
  color: #007AFF;
  background: #E6F2FF;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.hl-addr {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6E6E73;
}
.hl-dept-list {
  margin-top: 24rpx;
}
.hl-dept-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  margin-top: 16rpx;
}
.hl-dept-item-first {
  margin-top: 0;
}
.hl-dept-hover {
  opacity: 0.7;
}
.hl-dept-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D1D1F;
  flex-shrink: 0;
}
.hl-dept-desc {
  flex: 1;
  font-size: 28rpx;
  color: #6E6E73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hl-dept-arrow {
  font-size: 36rpx;
  color: #8E8E93;
  flex-shrink: 0;
}
@media (prefers-color-scheme: dark) {
  .hl-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
  .hl-title { color: #FFFFFF; }
  .hl-empty { background: #1C1C1E; border-color: #3A3A3C; }
  .hl-empty-title { color: #FFFFFF; }
  .hl-empty-desc { color: #8E8E93; }
  .hl-hospital {
    background: #2C2C2E;
    border-color: #3A3A3C;
  }
  .hl-name { color: #FFFFFF; }
  .hl-level { background: #007AFF; }
  .hl-rating, .hl-addr { color: #8E8E93; }
  .hl-tag { background: #1A3A5C; color: #64B5F6; }
  .hl-dept-item {
    background: #1C1C1E;
    border-color: #3A3A3C;
  }
  .hl-dept-name { color: #FFFFFF; }
  .hl-dept-desc { color: #8E8E93; }
  .hl-dept-arrow { color: #636366; }
}
