{
  "version": "2.0",
  "functions": [
    {
      "name": "queue-skill-handler",
      "type": "event",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 256,
      "installDependency": true,
      "dir": "cloudfunctions/queue-skill-handler",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "queue_tickets",
        "description": "排队票据集合",
        "indexes": [
          {
            "field": "ticketId",
            "unique": false
          },
          {
            "field": "storeId",
            "unique": false
          }
        ],
        "aclTag": "PRIVATE"
      }
    ]
  }
}
