{
  "apis": [
    {
      "name": "searchStores",
      "description": "查询可排队门店列表（业务对象：门店列表卡片）。调用前置条件：用户需要选择门店、搜索门店、比较不同门店排队快慢，或尚未提供明确门店上下文时。用户提供门店名、商圈或区域关键词时优先按关键词搜索；用户未提供关键词时返回默认可选门店列表。【严禁场景】禁止在已有明确 storeId 且用户要查看单门店排队状态时继续调用本接口，应改走 getStoreQueueStatus。",
      "_meta": {
        "ui": {
          "componentPath": "components/store-list-card/index"
        }
      },
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "门店搜索关键词。取值来源：用户原话中的门店名、商圈名或区域词（如『望京』『国贸』『三里屯』）。【禁止编造】用户未明确给出关键词时可留空，返回默认可选门店列表。"
          }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "description": "可选门店列表",
            "items": {
              "type": "object",
              "properties": {
                "storeId": { "type": "string", "description": "门店唯一 ID" },
                "storeName": { "type": "string", "description": "门店名称" },
                "distance": { "type": "string", "description": "距离文案" },
                "waitingCount": { "type": "number", "description": "当前前方排队人数" },
                "estimatedMinutes": { "type": "number", "description": "预计等待分钟数" },
                "queueEnabled": { "type": "boolean", "description": "是否可取号" }
              },
              "required": ["storeId", "storeName", "distance", "waitingCount", "estimatedMinutes", "queueEnabled"],
              "additionalProperties": false
            }
          },
          "total": { "type": "number", "description": "门店数量" },
          "keyword": { "type": "string", "description": "实际使用的关键词，无关键词时为空字符串" }
        },
        "required": ["items", "total", "keyword"],
        "additionalProperties": false
      }
    },
    {
      "name": "getStoreQueueStatus",
      "description": "查看单个门店当前排队状态（业务对象：门店排队状态卡片）。调用前置条件：已从门店列表中拿到具体 storeId，或上下文中已有明确门店。展示当前叫号、前方人数、预计等待、营业时间和是否可取号。【严禁场景】禁止在没有有效 storeId 的情况下调用；禁止从用户自然语言编造 storeId。上下文中没有 storeId 时应先调用 searchStores。",
      "_meta": {
        "ui": {
          "componentPath": "components/store-queue-status-card/index"
        }
      },
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "storeId": {
            "type": "string",
            "description": "门店唯一标识，必须来自上游 searchStores 返回的 items[].storeId 原值。【禁止编造】禁止从用户自然语言推断或拼接。上下文中无 storeId 时，应先调 searchStores。"
          }
        },
        "required": ["storeId"],
        "additionalProperties": false
      },
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "storeId": { "type": "string" },
          "storeName": { "type": "string" },
          "address": { "type": "string" },
          "businessHours": { "type": "string" },
          "queueEnabled": { "type": "boolean" },
          "queueStatusText": { "type": "string", "description": "取号状态文案，如『可取号』『暂停取号』" },
          "currentCallingNumber": { "type": "string", "description": "当前叫号" },
          "waitingCount": { "type": "number", "description": "当前前方排队人数" },
          "estimatedMinutes": { "type": "number", "description": "预计等待分钟数" }
        },
        "required": ["storeId", "storeName", "address", "businessHours", "queueEnabled", "queueStatusText", "currentCallingNumber", "waitingCount", "estimatedMinutes"],
        "additionalProperties": false
      }
    },
    {
      "name": "takeQueueNumber",
      "description": "为指定门店生成排队票（业务对象：取号结果卡片）。调用前置条件：已通过 getStoreQueueStatus 确认门店允许取号，并且已有上游返回的 storeId。成功后生成 ticketId 与排队号，并返回当前前方人数和预计等待时间。【严禁场景】禁止在无 storeId 时调用；禁止在门店暂停取号时向用户承诺已取号成功。",
      "_meta": {
        "ui": {
          "componentPath": "components/queue-ticket-card/index"
        }
      },
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "storeId": {
            "type": "string",
            "description": "门店唯一标识，必须来自上游 searchStores 或 getStoreQueueStatus 返回的 storeId 原值。【禁止编造】上下文中无 storeId 时应先完成门店选择。"
          },
          "partySize": {
            "type": "number",
            "minimum": 1,
            "maximum": 12,
            "description": "就餐人数。用户明确提到人数时按原话填写；用户未提及时留空，由后端按默认 2 人处理。"
          },
          "queueType": {
            "type": "string",
            "enum": ["dine_in", "service"],
            "description": "队列类型。仅允许：'dine_in'（堂食）/ 'service'（服务台）。用户未明确说明时留空，由后端走默认堂食。"
          }
        },
        "required": ["storeId"],
        "additionalProperties": false
      },
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "ticketId": { "type": "string", "description": "排队票唯一 ID" },
          "queueNumber": { "type": "string", "description": "排队号牌" },
          "storeId": { "type": "string" },
          "storeName": { "type": "string" },
          "aheadCount": { "type": "number", "description": "取号成功时前方人数" },
          "estimatedMinutes": { "type": "number", "description": "预计等待分钟数" },
          "takeTime": { "type": "string", "description": "取号时间 ISO 字符串" },
          "status": { "type": "string", "description": "票据状态，首版固定为 waiting" }
        },
        "required": ["ticketId", "queueNumber", "storeId", "storeName", "aheadCount", "estimatedMinutes", "takeTime", "status"],
        "additionalProperties": false
      }
    },
    {
      "name": "getQueueProgress",
      "description": "查询排队票当前进度（业务对象：排队进度卡片）。调用前置条件：上下文中已有有效 ticketId。展示当前状态、当前叫号、前方剩余人数、预计剩余等待时间和是否即将到号。【严禁场景】禁止在没有 ticketId 的情况下调用；禁止从用户自然语言编造 ticketId。上下文中无 ticketId 时，应先完成取号或让用户提供真实票据。",
      "_meta": {
        "ui": {
          "componentPath": "components/queue-progress-card/index"
        }
      },
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "ticketId": {
            "type": "string",
            "description": "排队票唯一标识，必须来自上游 takeQueueNumber 返回的 ticketId 原值。【禁止编造】上下文中无 ticketId 时禁止填写本字段，应先完成取号。"
          }
        },
        "required": ["ticketId"],
        "additionalProperties": false
      },
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "ticketId": { "type": "string" },
          "queueNumber": { "type": "string" },
          "storeName": { "type": "string" },
          "status": { "type": "string", "description": "waiting / calling / passed / completed" },
          "statusText": { "type": "string", "description": "状态文案" },
          "aheadCount": { "type": "number", "description": "前方剩余人数" },
          "currentCallingNumber": { "type": "string", "description": "当前叫号" },
          "remainingMinutes": { "type": "number", "description": "预计剩余等待分钟数" },
          "isAlmostReady": { "type": "boolean", "description": "是否即将到号" }
        },
        "required": ["ticketId", "queueNumber", "storeName", "status", "statusText", "aheadCount", "currentCallingNumber", "remainingMinutes", "isAlmostReady"],
        "additionalProperties": false
      }
    }
  ],
  "components": [
    {
      "path": "components/store-list-card/index",
      "relatedPage": "/pages/home/home"
    },
    {
      "path": "components/store-queue-status-card/index",
      "relatedPage": "/pages/home/home"
    },
    {
      "path": "components/queue-ticket-card/index",
      "relatedPage": "/pages/home/home"
    },
    {
      "path": "components/queue-progress-card/index",
      "relatedPage": "/pages/home/home"
    }
  ]
}
