/* WeCard 设计系统重构 - 暖色强调 */
.qp-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.qp-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.qp-title {
  font-size: 60rpx;
  font-weight: 600;
  color: #D4813D;
  line-height: 1.1;
}
.qp-store {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.qp-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.qp-badge.is-waiting { background: #FFF7ED; color: #D4813D; }
.qp-badge.is-calling { background: #E8F8EF; color: #12B76A; }
.qp-badge.is-passed,
.qp-badge.is-completed { background: #FEF3F2; color: #F04438; }
.qp-grid {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}
.qp-cell {
  flex: 1;
  background: #F5F5F7;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.qp-label {
  font-size: 24rpx;
  color: #6E6E73;
}
.qp-value {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.qp-hint {
  margin-top: 24rpx;
  padding: 20rpx 16rpx;
  background: #F5F5F7;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.qp-hint.is-ready {
  background: #E8F8EF;
  border-color: #A6F4C5;
  color: #12B76A;
}
.qp-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: linear-gradient(135deg, #D4813D 0%, #B86A38 100%);
}
.qp-btn-hover { opacity: 0.88; }
@media (prefers-color-scheme: dark) {
  .qp-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
  .qp-title { color: #FF9F0A; }
  .qp-store, .qp-label, .qp-hint { color: rgba(255,255,255,0.68); }
  .qp-value { color: #FFFFFF; }
  .qp-cell {
    background: #2C2C2E;
    border-color: rgba(255,255,255,0.08);
  }
  .qp-hint { background: #2C2C2E; border-color: rgba(255,255,255,0.08); }
  .qp-hint.is-ready { background: #1A3A2A; border-color: #14532D; color: #6EE7B7; }
  .qp-btn { background: #F2F2F7; color: #1D1D1F; }
  .qp-badge.is-waiting { background: #3A2E1A; color: #FFD60A; }
  .qp-badge.is-calling { background: #1A3A2A; color: #6EE7B7; }
  .qp-badge.is-passed,
  .qp-badge.is-completed { background: #3B1D24; color: #FDA4AF; }
}
