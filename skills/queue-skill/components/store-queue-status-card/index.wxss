/* WeCard 设计系统重构 - 暖色强调 */
.sq-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.sq-head,
.sq-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sq-title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sq-badge {
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.sq-badge.is-on { background: #E8F8EF; color: #12B76A; }
.sq-badge.is-off { background: #FEF3F2; color: #F04438; }
.sq-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6E6E73;
  line-height: 1.4;
}
.sq-grid {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}
.sq-cell {
  flex: 1;
  background: #F5F5F7;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.sq-label {
  font-size: 24rpx;
  color: #6E6E73;
}
.sq-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.sq-actions {
  margin-top: 24rpx;
  gap: 16rpx;
}
.sq-primary,
.sq-secondary,
.sq-disabled {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.sq-primary {
  color: #FFFFFF;
  background: linear-gradient(135deg, #D4813D 0%, #B86A38 100%);
}
.sq-secondary {
  color: #D4813D;
  background: #FFF7ED;
}
.sq-disabled {
  color: #8E8E93;
  background: #F1F5F9;
}
.sq-primary-hover,
.sq-secondary-hover { opacity: 0.88; }
@media (prefers-color-scheme: dark) {
  .sq-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
  .sq-title, .sq-value { color: #FFFFFF; }
  .sq-desc, .sq-label { color: rgba(255,255,255,0.68); }
  .sq-cell {
    background: #2C2C2E;
    border-color: rgba(255,255,255,0.08);
  }
  .sq-badge.is-on { background: #1A3A2A; color: #6EE7B7; }
  .sq-badge.is-off { background: #3B1D24; color: #FDA4AF; }
  .sq-primary { background: #F2F2F7; color: #1D1D1F; }
  .sq-secondary { color: #FF9F0A; background: #2C2C2E; }
  .sq-disabled { color: #636366; background: #1C1C1E; }
}
