.sl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sl-title {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.sl-empty {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F7F7F8;
  border: 1px solid #E5E5EA;
}

.sl-empty-title {
  font-size: 32rpx;
  line-height: 44rpx;
  color: #1D1D1F;
}

.sl-empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #6E6E73;
}

.sl-item {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
}

.sl-item-head,
.sl-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.sl-store-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sl-distance {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #8E8E93;
  flex-shrink: 0;
}

.sl-meta-row {
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.sl-meta {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #6E6E73;
}

.sl-badge {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.sl-badge.is-on {
  background: #ECFDF3;
  color: #027A48;
}

.sl-badge.is-off {
  background: #FEF3F2;
  color: #B42318;
}

.sl-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-start;
}

.sl-btn {
  min-width: 192rpx;
  height: 80rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sl-btn-hover {
  opacity: 0.86;
}

@media (prefers-color-scheme: dark) {
  .sl-card,
  .sl-item {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .sl-title,
  .sl-empty-title,
  .sl-store-name {
    color: #FFFFFF;
  }

  .sl-empty {
    background: #2C2C2E;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .sl-empty-desc,
  .sl-meta,
  .sl-distance {
    color: rgba(255, 255, 255, 0.68);
  }

  .sl-badge.is-on {
    background: rgba(18, 183, 106, 0.16);
    color: #3DDC97;
  }

  .sl-badge.is-off {
    background: rgba(240, 68, 56, 0.16);
    color: #FF8A80;
  }

  .sl-btn {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
