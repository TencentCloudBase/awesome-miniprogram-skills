/* ratio=4:3；现代暖橙中性色系 */
.qt-card {
  background: linear-gradient(180deg, #FFF7ED 0%, #FFFFFF 100%);
  border: 1px solid #FED7AA;
  border-radius: 1.6vw;
  padding: 3.2vw;
  box-sizing: border-box;
  box-shadow: 0 10rpx 36rpx rgba(249, 115, 22, 0.12);
}
.qt-badge {
  display: inline-block;
  padding: 0.8vw 2.13vw;
  border-radius: 999rpx;
  background: #DCFCE7;
  color: #15803D;
  font-size: 3.2vw;
}
.qt-number {
  margin-top: 2.13vw;
  font-size: 9.6vw;
  font-weight: 700;
  color: #C2410C;
  line-height: 1.1;
}
.qt-store {
  margin-top: 1.33vw;
  font-size: 4.53vw;
  font-weight: 600;
  color: #0F172A;
}
.qt-meta {
  margin-top: 1.33vw;
  font-size: 3.2vw;
  color: #64748B;
}
.qt-grid {
  margin-top: 3.2vw;
  display: flex;
  gap: 2.13vw;
}
.qt-cell {
  flex: 1;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid #E2E8F0;
  border-radius: 1.6vw;
  padding: 2.67vw 2.13vw;
  text-align: center;
}
.qt-label {
  font-size: 3.2vw;
  color: #64748B;
}
.qt-value {
  margin-top: 1.33vw;
  font-size: 4vw;
  font-weight: 600;
  color: #0F172A;
}
.qt-btn {
  margin-top: 3.2vw;
  height: 10.67vw;
  line-height: 10.67vw;
  text-align: center;
  border-radius: 1.6vw;
  font-size: 3.73vw;
  color: #FFFFFF;
  background: linear-gradient(135deg, #EF4444 0%, #F97316 100%);
}
.qt-btn-hover { opacity: 0.88; }
@media (prefers-color-scheme: dark) {
  .qt-card {
    background: linear-gradient(180deg, #431407 0%, #0F172A 100%);
    border-color: #7C2D12;
    box-shadow: none;
  }
  .qt-number { color: #FDBA74; }
  .qt-store, .qt-value { color: #F8FAFC; }
  .qt-meta, .qt-label { color: #94A3B8; }
  .qt-cell { background: rgba(15, 23, 42, 0.72); border-color: #334155; }
  .qt-badge { background: #123827; color: #6EE7B7; }
  .qt-btn { background: linear-gradient(135deg, #FB7185 0%, #FB923C 100%); }
}