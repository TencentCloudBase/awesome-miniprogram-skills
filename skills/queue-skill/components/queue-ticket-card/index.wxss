/* WeCard 设计系统重构 - 暖色强调 */
.qt-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.qt-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #E8F8EF;
  color: #12B76A;
  font-size: 24rpx;
}
.qt-number {
  margin-top: 16rpx;
  font-size: 72rpx;
  font-weight: 700;
  color: #D4813D;
  line-height: 1.1;
}
.qt-store {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.qt-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.qt-grid {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}
.qt-cell {
  flex: 1;
  background: #F5F5F7;
  border: 1px solid #E5E5EA;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.qt-label {
  font-size: 24rpx;
  color: #6E6E73;
}
.qt-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.qt-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: linear-gradient(135deg, #D4813D 0%, #B86A38 100%);
}
.qt-btn-hover { opacity: 0.88; }
@media (prefers-color-scheme: dark) {
  .qt-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }
  .qt-number { color: #FF9F0A; }
  .qt-store, .qt-value { color: #FFFFFF; }
  .qt-meta, .qt-label { color: rgba(255,255,255,0.68); }
  .qt-cell { background: #2C2C2E; border-color: rgba(255,255,255,0.08); }
  .qt-badge { background: #1A3A2A; color: #6EE7B7; }
  .qt-btn { background: #F2F2F7; color: #1D1D1F; }
}
