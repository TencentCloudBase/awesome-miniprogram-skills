{
  "version": "2.0",
  "functions": [
    {
      "name": "shopping-skill-handler",
      "type": "event",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 256,
      "installDependency": true,
      "dir": "cloudfunctions/shopping-skill-handler",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "shopping_orders",
        "description": "潮玩购物订单",
        "indexes": [
          {
            "field": "openid",
            "unique": false
          },
          {
            "field": "status",
            "unique": false
          }
        ]
      }
    ]
  }
}