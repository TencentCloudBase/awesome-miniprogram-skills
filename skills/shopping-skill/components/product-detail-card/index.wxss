/* WeCard Design System - Product Detail Card
 * 品牌点缀：#D4813D（≤5% 面积，用于价格等小区域）
 * Neutral: #2C2C2E
 */
.pd-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  width: 100%;
}

.pd-img {
  width: 100%;
  height: 360rpx;
  background-color: #F5F5F7;
}

.pd-body {
  padding: 20rpx 24rpx 24rpx;
}

.pd-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.pd-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #D4813D;
  margin-top: 8rpx;
}

.pd-cat {
  font-size: 20rpx;
  color: #6E6E73;
  background: #F5F5F7;
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
}

.pd-desc {
  font-size: 28rpx;
  color: #6E6E73;
  line-height: 1.5;
  margin-top: 14rpx;
}

.pd-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.pd-tag {
  font-size: 20rpx;
  color: #D4813D;
  background: #F5F5F7;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid #D4813D;
}

.pd-stores {
  margin-top: 18rpx;
  padding: 16rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.pd-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 10rpx;
}

.pd-store-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.pd-store-name {
  color: #1D1D1F;
  flex: 1;
}

.pd-store-stock {
  color: #12B76A;
  font-weight: 500;
}

.pd-store-soldout {
  color: #8E8E93;
}

.pd-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.pd-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.pd-btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.pd-btn-primary {
  background: #2C2C2E;
  color: #FFFFFF;
}

.pd-btn-secondary {
  background: #F5F5F7;
  color: #2C2C2E;
  border: 1rpx solid #E5E5EA;
}

@media (prefers-color-scheme: dark) {
  .pd-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .pd-img { background-color: rgba(255,255,255,0.08); }
  .pd-name { color: #FFFFFF; }
  .pd-cat { color: rgba(255,255,255,0.68); background: rgba(255,255,255,0.08); }
  .pd-desc { color: rgba(255,255,255,0.68); }
  .pd-tag { color: #D4813D; background: rgba(255,255,255,0.08); border-color: #D4813D; }
  .pd-stores { background: rgba(255,255,255,0.08); }
  .pd-section-title { color: #FFFFFF; }
  .pd-store-name { color: #FFFFFF; }
  .pd-store-soldout { color: rgba(255,255,255,0.5); }
  .pd-btn-secondary { background: rgba(255,255,255,0.08); color: #F2F2F7; border-color: rgba(255,255,255,0.12); }
  .pd-btn-primary { background: #F2F2F7; color: #1D1D1F; }
}
