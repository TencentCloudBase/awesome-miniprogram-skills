/* WeCard Design System - Order Success Card
 * Success: #12B76A, Neutral: #2C2C2E
 * 品牌点缀：#D4813D（≤5% 面积）
 */
.os-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  text-align: center;
}

.os-icon {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: #12B76A;
  color: #FFFFFF;
  font-size: 48rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  text-align: center;
}

.os-status {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.os-divider {
  height: 1rpx;
  background: #E5E5EA;
  margin: 20rpx 0;
}

.os-product {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  text-align: left;
}

.os-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  background-color: #F5F5F7;
}

.os-product-info {
  flex: 1;
  min-width: 0;
}

.os-product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.os-product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #D4813D;
  margin-top: 4rpx;
}

.os-details {
  text-align: left;
  margin-bottom: 16rpx;
}

.os-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.os-detail-label {
  color: #6E6E73;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.os-detail-value {
  color: #1D1D1F;
  text-align: right;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.os-tip {
  font-size: 20rpx;
  color: #8E8E93;
  margin-bottom: 20rpx;
  padding: 12rpx;
  background: #F5F5F7;
  border-radius: 12rpx;
}

.os-btn {
  text-align: center;
  padding: 20rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
}

.os-btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

@media (prefers-color-scheme: dark) {
  .os-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .os-status { color: #FFFFFF; }
  .os-divider { background: rgba(255,255,255,0.08); }
  .os-product { background: rgba(255,255,255,0.08); }
  .os-product-name { color: #FFFFFF; }
  .os-detail-label { color: rgba(255,255,255,0.68); }
  .os-detail-value { color: #FFFFFF; }
  .os-tip { color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.08); }
}
