/* WeCard Design System - Product List Card
 * 品牌点缀：#D4813D（≤5% 面积，用于价格等小区域）
 * Neutral: #2C2C2E
 */
.pl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.pl-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.pl-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.pl-sub {
  font-size: 24rpx;
  color: #8E8E93;
}

.pl-list {
  display: flex;
  flex-direction: column;
}

.pl-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F5F5F7;
  border-radius: 24rpx;
  padding: 16rpx;
  box-sizing: border-box;
  margin-bottom: 14rpx;
}

.pl-item-hover {
  opacity: 0.88;
  transform: scale(0.99);
}

.pl-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  background-color: #F5F5F7;
  flex-shrink: 0;
}

.pl-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.pl-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pl-desc {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pl-foot {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 8rpx;
}

.pl-cat {
  font-size: 20rpx;
  color: #6E6E73;
  background: #FFFFFF;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

.pl-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #D4813D;
}

.pl-empty {
  padding: 30rpx 16rpx;
  text-align: center;
}

.pl-empty-title {
  font-size: 28rpx;
  color: #2C2C2E;
  font-weight: 600;
}

.pl-empty-sub {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

@media (prefers-color-scheme: dark) {
  .pl-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .pl-title { color: #FFFFFF; }
  .pl-sub { color: rgba(255,255,255,0.5); }
  .pl-item { background: rgba(255,255,255,0.08); }
  .pl-img { background-color: rgba(255,255,255,0.08); }
  .pl-name { color: #FFFFFF; }
  .pl-desc { color: rgba(255,255,255,0.68); }
  .pl-cat { color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.08); }
  .pl-empty-title { color: #F2F2F7; }
  .pl-empty-sub { color: rgba(255,255,255,0.5); }
}
