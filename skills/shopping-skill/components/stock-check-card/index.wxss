/* WeCard Design System - Stock Check Card
 * Success: #12B76A, Neutral: #2C2C2E
 * 品牌点缀：#D4813D（≤5% 面积）
 */
.sc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.sc-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.sc-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  background-color: #F5F5F7;
}

.sc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  flex: 1;
}

.sc-list {
  display: flex;
  flex-direction: column;
}

.sc-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #F5F5F7;
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
}

.sc-item-hover {
  opacity: 0.88;
}

.sc-item-left {
  flex: 1;
  min-width: 0;
}

.sc-store-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.sc-store-addr {
  font-size: 20rpx;
  color: #6E6E73;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sc-item-right {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.sc-stock {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.sc-stock-avail {
  color: #12B76A;
  background: #E8F8F0;
}

.sc-stock-soldout {
  color: #8E8E93;
  background: #F5F5F7;
}

.sc-empty {
  padding: 30rpx 16rpx;
  text-align: center;
}

.sc-empty-text {
  font-size: 24rpx;
  color: #8E8E93;
}

@media (prefers-color-scheme: dark) {
  .sc-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .sc-img { background-color: rgba(255,255,255,0.08); }
  .sc-title { color: #FFFFFF; }
  .sc-item { background: rgba(255,255,255,0.08); }
  .sc-store-name { color: #FFFFFF; }
  .sc-store-addr { color: rgba(255,255,255,0.68); }
  .sc-stock-avail { color: #12B76A; background: rgba(18, 183, 106, 0.15); }
  .sc-stock-soldout { color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.08); }
  .sc-empty-text { color: rgba(255,255,255,0.5); }
}
