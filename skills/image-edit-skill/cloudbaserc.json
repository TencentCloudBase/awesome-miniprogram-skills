{
  "version": "2.0",
  "functions": [
    {
      "name": "image-edit-handler",
      "type": "event",
      "timeout": 120,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "memorySize": 512,
      "installDependency": true,
      "dir": "cloudfunctions/image-edit-handler",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "database": {
    "collections": [
      {
        "name": "ai_edit_history",
        "description": "AI 图片编辑历史记录",
        "aclTag": "PRIVATE",
        "indexes": [
          {
            "field": "_openid"
          },
          {
            "field": "createTime"
          }
        ]
      }
    ]
  }
}
