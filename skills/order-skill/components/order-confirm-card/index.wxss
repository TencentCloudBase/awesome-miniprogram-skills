/* WeCard Design System — Order Confirm Card */
.oc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.oc-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}
.oc-status-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: rgba(212, 129, 61, 0.08);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #D4813D;
  margin-bottom: 16rpx;
}
.oc-rest-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}
.oc-items {
  margin-bottom: 16rpx;
}
.oc-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #1D1D1F;
}
.oc-item-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.oc-item-qty {
  margin: 0 16rpx;
  color: #6E6E73;
  font-size: 24rpx;
}
.oc-item-price {
  flex-shrink: 0;
  color: #1D1D1F;
}
.oc-divider {
  height: 1px;
  background: rgba(0, 0, 0, 0.06);
  margin: 16rpx 0;
}
.oc-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.oc-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}
.oc-total-amount {
  color: #D4813D;
  font-size: 36rpx;
}
.oc-delivery-info {
  background: rgba(212, 129, 61, 0.06);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
.oc-delivery-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}
.oc-delivery-row-last {
  margin-bottom: 0;
}
.oc-delivery-label {
  color: #6E6E73;
}
.oc-note {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8E8E93;
  line-height: 1.5;
}
.oc-btn-row {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}
.oc-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: linear-gradient(135deg, #D4813D, #B86A38);
  border-radius: 999rpx;
}
.oc-btn-hover {
  opacity: 0.88;
}
.oc-btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #D4813D;
  background: rgba(212, 129, 61, 0.08);
  border-radius: 999rpx;
}
.oc-btn-secondary-hover {
  opacity: 0.8;
}
@media (prefers-color-scheme: dark) {
  .oc-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .oc-title, .oc-rest-name, .oc-item, .oc-item-price, .oc-total-row { color: #FFFFFF; }
  .oc-item-qty, .oc-summary, .oc-delivery-label { color: rgba(255,255,255,0.68); }
  .oc-status-badge { background: rgba(255,255,255,0.08); color: #F5A97F; }
  .oc-divider { background: rgba(255,255,255,0.10); }
  .oc-total-amount { color: #F5A97F; }
  .oc-delivery-info { background: rgba(255,255,255,0.06); }
  .oc-delivery-row { color: #FFFFFF; }
  .oc-note { color: rgba(255,255,255,0.48); }
  .oc-btn-secondary { background: rgba(255,255,255,0.08); color: #F5A97F; }
}
