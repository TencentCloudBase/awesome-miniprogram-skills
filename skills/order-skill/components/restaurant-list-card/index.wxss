/* WeCard Design System — Restaurant List Card */
.rl-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.rl-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}
.rl-empty {
  padding: 48rpx 24rpx;
  text-align: center;
  background: rgba(212, 129, 61, 0.06);
  border-radius: 16rpx;
}
.rl-empty-title {
  font-size: 28rpx;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}
.rl-empty-desc {
  font-size: 24rpx;
  color: #6E6E73;
}
.rl-item {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(212, 129, 61, 0.06);
  border-radius: 16rpx;
  cursor: pointer;
}
.rl-item-active {
  opacity: 0.85;
}
.rl-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.rl-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rl-tags {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.rl-tag {
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 16rpx;
  background: #F5F5F7;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.rl-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.rl-rating {
  color: #D4813D;
  font-weight: 600;
}
.rl-sales {
  color: #6E6E73;
}
.rl-distance {
  color: #6E6E73;
}
.rl-info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6E6E73;
}
.rl-fee {
  color: #6E6E73;
}
.rl-time {
  color: #6E6E73;
}
.rl-btn {
  margin-top: 16rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}
.rl-btn-hover {
  opacity: 0.88;
}
@media (prefers-color-scheme: dark) {
  .rl-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .rl-title { color: #FFFFFF; }
  .rl-empty { background: rgba(255,255,255,0.06); }
  .rl-empty-title { color: #FFFFFF; }
  .rl-empty-desc { color: rgba(255,255,255,0.68); }
  .rl-item { background: rgba(255,255,255,0.06); }
  .rl-name { color: #FFFFFF; }
  .rl-tag { background: #2C2C2E; color: rgba(255,255,255,0.68); }
  .rl-meta-row, .rl-rating, .rl-sales, .rl-distance, .rl-info-row, .rl-fee, .rl-time { color: rgba(255,255,255,0.68); }
  .rl-btn { background: #F2F2F7; color: #1D1D1F; }
}
