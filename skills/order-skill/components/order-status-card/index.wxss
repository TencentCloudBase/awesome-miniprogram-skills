.os-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.os-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.os-title {
  flex: 1;
  min-width: 0;
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.os-badge {
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6E6E73;
  background: #F2F2F7;
  flex-shrink: 0;
}

.os-badge-delivering {
  background: #FFF7ED;
  color: #B54708;
}

.os-badge-completed {
  background: #ECFDF3;
  color: #027A48;
}

.os-badge-pending {
  background: #F2F2F7;
  color: #6E6E73;
}

.os-rest-name {
  margin-top: 16rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  color: #1D1D1F;
}

.os-progress {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
}

.os-step {
  flex: 1;
  position: relative;
  text-align: center;
}

.os-step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  background: #D1D1D6;
}

.os-step-dot.active,
.os-step-dot.current {
  background: #007AFF;
}

.os-step-dot.current {
  box-shadow: 0 0 0 8rpx rgba(0, 122, 255, 0.12);
}

.os-step-label {
  font-size: 24rpx;
  line-height: 32rpx;
  color: #8E8E93;
}

.os-step-label.active {
  color: #1D1D1F;
}

.os-step-line {
  position: absolute;
  top: 8rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background: #E5E5EA;
}

.os-step-line.active {
  background: #007AFF;
}

.os-order-id {
  margin-top: 24rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #8E8E93;
}

.os-info {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #F7F7F8;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
}

.os-info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #1D1D1F;
}

.os-info-row-last {
  margin-bottom: 0;
}

.os-info-label {
  flex-shrink: 0;
  color: #6E6E73;
}

.os-info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.os-divider {
  height: 2rpx;
  margin: 24rpx 0 16rpx;
  background: #F0F0F0;
}

.os-btn-row {
  display: flex;
  gap: 16rpx;
}

.os-btn {
  min-width: 192rpx;
  height: 80rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.os-btn-hover {
  opacity: 0.86;
}

@media (prefers-color-scheme: dark) {
  .os-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .os-title,
  .os-rest-name,
  .os-info-row,
  .os-info-value,
  .os-step-label.active {
    color: #FFFFFF;
  }

  .os-badge,
  .os-badge-pending {
    background: #2C2C2E;
    color: rgba(255, 255, 255, 0.68);
  }

  .os-badge-delivering {
    background: rgba(255, 159, 10, 0.14);
    color: #FFB340;
  }

  .os-badge-completed {
    background: rgba(18, 183, 106, 0.16);
    color: #3DDC97;
  }

  .os-step-dot {
    background: rgba(255, 255, 255, 0.18);
  }

  .os-step-dot.active,
  .os-step-dot.current,
  .os-step-line.active {
    background: #0A84FF;
  }

  .os-step-line,
  .os-divider {
    background: rgba(255, 255, 255, 0.08);
  }

  .os-step-label,
  .os-order-id,
  .os-info-label {
    color: rgba(255, 255, 255, 0.68);
  }

  .os-info {
    background: #2C2C2E;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .os-btn {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
