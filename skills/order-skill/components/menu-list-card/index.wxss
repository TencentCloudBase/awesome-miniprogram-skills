/* WeCard Design System — Menu List Card */
.ml-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.ml-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ml-rest-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.ml-rest-meta {
  font-size: 24rpx;
  color: #8E8E93;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.ml-list {
  display: flex;
  flex-direction: column;
}

.ml-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}
.ml-item--first {
  border-top: none;
}

.ml-item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #F5F5F7;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.ml-info {
  flex: 1;
  min-width: 0;
}

.ml-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ml-item-desc {
  font-size: 24rpx;
  color: #6E6E73;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.ml-item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.ml-item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #D4813D;
}

.ml-item-sales {
  font-size: 24rpx;
  color: #8E8E93;
}

.ml-omitted {
  text-align: center;
  font-size: 24rpx;
  color: #8E8E93;
  padding: 16rpx 0 4rpx;
}

@media (prefers-color-scheme: dark) {
  .ml-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .ml-rest-name { color: #FFFFFF; }
  .ml-rest-meta { color: rgba(255,255,255,0.68); }
  .ml-item { border-color: rgba(255,255,255,0.08); }
  .ml-item--first { border-color: transparent; }
  .ml-item-name { color: #FFFFFF; }
  .ml-item-desc { color: rgba(255,255,255,0.68); }
  .ml-item-price { color: #F5A97F; }
  .ml-item-sales { color: rgba(255,255,255,0.68); }
  .ml-omitted { color: rgba(255,255,255,0.68); }
}
