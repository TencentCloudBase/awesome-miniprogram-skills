<view class="ml-card">
  <view class="ml-header">
    <view class="ml-rest-name">{{restaurant.name}}</view>
    <view class="ml-rest-meta">★ {{restaurant.rating}} | 月售 {{restaurant.monthlySales}}</view>
  </view>

  <view wx:if="{{!items.length}}" class="ml-empty">
    <view class="ml-empty-title">暂无菜品</view>
    <view class="ml-empty-desc">该餐厅暂未上架菜品</view>
  </view>

  <block wx:for="{{items}}" wx:key="itemId" wx:for-index="index">
    <view class="ml-item {{index === items.length - 1 ? 'ml-item-last' : ''}}">
      <view class="ml-info">
        <view class="ml-item-name">{{item.name}}</view>
        <view wx:if="{{item.description}}" class="ml-item-desc">{{item.description}}</view>
        <view class="ml-item-sales">月售 {{item.monthlySales}}</view>
        <view class="ml-item-price">
          <text class="ml-item-price-unit">¥</text>{{item.price.toFixed(1)}}
        </view>
        <view
          class="ml-add-btn"
          hover-class="ml-add-btn-hover"
          bind:tap="onTapAdd"
          data-item-id="{{item.itemId}}"
          data-item-name="{{item.name}}"
          data-item-price="{{item.price}}"
        >+ 加入</view>
      </view>
      <image class="ml-item-img" src="{{item.image}}" mode="aspectFill" />
    </view>
  </block>

  <view wx:if="{{cartCount > 0}}" class="ml-footer">
    <view class="ml-cart-summary">
      已选 <text class="ml-cart-total">{{cartCount}}</text> 件 | ¥<text class="ml-cart-total">{{cartTotal.toFixed(1)}}</text>
    </view>
    <view
      class="ml-order-btn"
      hover-class="ml-order-btn-hover"
      bind:tap="onTapOrder"
    >去下单</view>
  </view>
</view>
