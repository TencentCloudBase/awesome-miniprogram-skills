/*
 * WeCard 基线: 普通卡片
 * ratio: 4:3
 * 色源: WeCard 中性色板 — bg-card #FFFFFF, text-primary #1D1D1F, text-secondary #6E6E73
 *       暗黑: bg-card #1C1C1E, text-primary #FFFFFF, text-secondary rgba(255,255,255,.68)
 */

/* === WeCard 容器 === */
.wecard {
  display: flex;
  flex-direction: column;
  padding: 16px;
  background: #FFFFFF;
  border-radius: 12px;
  box-sizing: border-box;
  width: 100%;
}

/* === Header === */
.wecard-header {
  display: flex;
  align-items: center;
  height: 40px;
  margin-bottom: 8px;
}

.tag {
  display: flex;
  align-items: center;
  height: 20px;
  padding: 0 8px;
  font-size: 12px;
  font-weight: 400;
  border-radius: 10px;
  background: #F5F5F7;
  color: #6E6E73;
  line-height: 20px;
}

/* === Content === */
.wecard-content {
  flex: 1;
  margin-bottom: 12px;
}

.text-body {
  display: block;
  font-size: 14px;
  font-weight: 400;
  color: #1D1D1F;
  line-height: 1.6;
  word-break: break-word;
}

.btn-expand {
  margin-top: 8px;
}

/* === Footer === */
.wecard-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.model-switcher {
  display: flex;
  gap: 8px;
  margin-left: auto;
}

/* === 按钮规范: 胶囊 999px, 高 40px, 字号 14px/500 === */
.btn-primary {
  height: 40px;
  min-width: 96px;
  padding: 0 16px;
  font-size: 14px;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999px;
  border: none;
  line-height: 40px;
  text-align: center;
}


.btn-secondary {
  height: 40px;
  min-width: 96px;
  padding: 0 16px;
  font-size: 14px;
  font-weight: 500;
  color: #1D1D1F;
  background: #F2F2F7;
  border-radius: 999px;
  border: none;
  line-height: 40px;
  text-align: center;
}


.btn-ghost {
  height: 36px;
  padding: 0 12px;
  font-size: 12px;
  font-weight: 500;
  color: #1D1D1F;
  background: transparent;
  border: 1px solid #E5E5EA;
  border-radius: 999px;
  line-height: 36px;
  text-align: center;
}


/* === 暗黑模式 === */
@media (prefers-color-scheme: dark) {
  .wecard {
    background: #1C1C1E;
  }

  .text-body {
    color: #FFFFFF;
  }

  .tag {
    background: #2C2C2E;
    color: rgba(255, 255, 255, 0.68);
  }

  .btn-primary {
    background: #FFFFFF;
    color: #1D1D1F;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.12);
    color: #FFFFFF;
  }

  .btn-ghost {
    color: #FFFFFF;
    border-color: rgba(255, 255, 255, 0.08);
  }
}
