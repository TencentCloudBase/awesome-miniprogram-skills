/* skills/water-tracker/components/water-records/index.wxss */
/* WeCard Design System — Neutral色系 */

.records-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.25;
  color: #1D1D1F;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.percent {
  margin-left: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.25;
  color: #12B76A;
}

.bar {
  width: 100%;
  height: 16rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background-color: #F5F5F7;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background-color: #12B76A;
}

.today-status {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.day-list {
  margin-top: 32rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
}

.day-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.day-date {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  color: #1D1D1F;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.day-total {
  width: 160rpx;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
  color: #6E6E73;
}

.day-percent {
  width: 90rpx;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
  color: #12B76A;
}

.omitted {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.primary-action {
  box-sizing: border-box;
  width: 100%;
  margin-top: 32rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 80rpx;
  text-align: center;
}

.primary-action-hover {
  opacity: 0.82;
}

@media (prefers-color-scheme: dark) {
  .records-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .title,
  .day-date {
    color: #FFFFFF;
  }

  .subtitle,
  .today-status,
  .day-total,
  .omitted {
    color: rgba(255, 255, 255, 0.68);
  }

  .bar {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .day-list {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .day-row {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .primary-action {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
