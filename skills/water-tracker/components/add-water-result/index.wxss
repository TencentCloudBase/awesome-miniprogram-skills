/* skills/water-tracker/components/add-water-result/index.wxss */
/* WeCard Design System — Neutral色系 */

.water-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.25;
  color: #1D1D1F;
}

.date {
  margin-left: 16rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.summary {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-top: 32rpx;
}

.total {
  font-size: 72rpx;
  font-weight: 600;
  line-height: 1;
  color: #12B76A;
}

.unit {
  margin-left: 16rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.bar {
  width: 100%;
  height: 16rpx;
  margin-top: 32rpx;
  border-radius: 999rpx;
  background-color: #F5F5F7;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background-color: #12B76A;
}

.status {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #6E6E73;
}

.primary-action {
  box-sizing: border-box;
  width: 100%;
  margin-top: 32rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #2C2C2E;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 80rpx;
  text-align: center;
}

.primary-action-hover {
  opacity: 0.82;
}

@media (prefers-color-scheme: dark) {
  .water-card {
    background: #1C1C1E;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .title {
    color: #FFFFFF;
  }

  .date,
  .unit,
  .status {
    color: rgba(255, 255, 255, 0.68);
  }

  .bar {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .primary-action {
    background: #F2F2F7;
    color: #1D1D1F;
  }
}
