/* skills/party-skill/components/recommend-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.rc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.rc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.rc-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.rc-filters {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.rc-filter {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #6E6E73;
  background: #F5F5F7;
  border-radius: 20rpx;
}

.rc-filter.is-active {
  color: #FFFFFF;
  background: #2C2C2E;
}

.rc-empty {
  padding: 48rpx 32rpx;
  text-align: center;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.rc-empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.rc-empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8E8E93;
}

.rc-list {
  overflow: hidden;
}

.rc-list-inner {
  display: flex;
  flex-direction: column;
}

.rc-item {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.rc-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rc-item-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rc-item-type {
  font-size: 24rpx;
  color: #D4813D;
  background: #F5F5F7;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.rc-item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.rc-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #6E6E73;
}

.rc-star {
  width: 24rpx;
  height: 24rpx;
  background: #D4813D;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

.rc-price, .rc-distance, .rc-capacity {
  font-size: 24rpx;
  color: #6E6E73;
}

.rc-address {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 8rpx;
}

.rc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.rc-tag {
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: #6E6E73;
  background: #F5F5F7;
  border-radius: 20rpx;
}

@media (prefers-color-scheme: dark) {
  .rc-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .rc-title { color: #FFFFFF; }
  .rc-filter { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.68); }
  .rc-filter.is-active { background: #F2F2F7; color: #1D1D1F; }
  .rc-empty { background: rgba(255,255,255,0.05); }
  .rc-empty-title { color: #FFFFFF; }
  .rc-empty-desc { color: rgba(255,255,255,0.48); }
  .rc-item { background: rgba(255,255,255,0.05); }
  .rc-item-name { color: #FFFFFF; }
  .rc-item-type { color: #D4813D; background: rgba(212, 129, 61, 0.12); }
  .rc-rating, .rc-price, .rc-distance, .rc-capacity { color: rgba(255,255,255,0.68); }
  .rc-address { color: rgba(255,255,255,0.48); }
  .rc-tag { color: rgba(255,255,255,0.68); background: rgba(255,255,255,0.08); }
}
