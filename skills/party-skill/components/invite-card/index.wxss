/* skills/party-skill/components/invite-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.ic-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.ic-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  text-align: center;
}

.ic-hint {
  font-size: 24rpx;
  color: #6E6E73;
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.ic-empty {
  padding: 48rpx;
  text-align: center;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.ic-empty-text {
  font-size: 28rpx;
  color: #6E6E73;
}

.ic-friend {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.ic-friend.is-selected {
  background: #F0F0F2;
}

.ic-avatar {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 50%;
  flex-shrink: 0;
}

.ic-friend-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.ic-friend-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
}

.ic-friend-status {
  display: block;
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 8rpx;
}
.ic-friend-status.is-accepted { color: #12B76A; }
.ic-friend-status.is-declined { color: #F04438; }
.ic-friend-status.is-organizer { color: #D4813D; }

.ic-check {
  width: 40rpx;
  height: 40rpx;
  background: #F0F0F2;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.ic-check.is-checked {
  background: #2C2C2E;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ic-check-inner {
  width: 16rpx;
  height: 8rpx;
  border-left: 3rpx solid white;
  border-bottom: 3rpx solid white;
  transform: rotate(-45deg);
  margin-bottom: 4rpx;
}

.ic-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}

.ic-btn.is-disabled {
  opacity: 0.35;
}

.ic-btn-hover {
  opacity: 0.85;
}

.ic-result {
  text-align: center;
}

.ic-result-mark {
  width: 96rpx;
  height: 96rpx;
  margin: 16rpx auto 16rpx;
  background: #12B76A;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ic-result-mark-inner {
  width: 32rpx;
  height: 16rpx;
  border-left: 4rpx solid white;
  border-bottom: 4rpx solid white;
  transform: rotate(-45deg);
  margin-bottom: 4rpx;
}

.ic-result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.ic-result-desc {
  font-size: 24rpx;
  color: #6E6E73;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.ic-friend-list {
  text-align: left;
}

@media (prefers-color-scheme: dark) {
  .ic-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .ic-title, .ic-result-title { color: #FFFFFF; }
  .ic-hint, .ic-result-desc, .ic-empty-text { color: rgba(255,255,255,0.68); }
  .ic-empty { background: rgba(255,255,255,0.05); }
  .ic-friend { background: rgba(255,255,255,0.05); }
  .ic-friend.is-selected { background: rgba(255,255,255,0.10); }
  .ic-friend-name { color: #FFFFFF; }
  .ic-friend-status { color: rgba(255,255,255,0.68); }
  .ic-friend-status.is-accepted { color: #12B76A; }
  .ic-friend-status.is-declined { color: #F04438; }
  .ic-friend-status.is-organizer { color: #D4813D; }
  .ic-check { background: rgba(255,255,255,0.12); }
  .ic-check.is-checked { background: #F2F2F7; }
}
