/* skills/party-skill/components/party-detail-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.pdc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.pdc-banner {
  text-align: center;
  padding: 32rpx 0;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.pdc-theme {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.pdc-status {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}

.pdc-section {
  margin-bottom: 24rpx;
}

.pdc-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #6E6E73;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.pdc-row {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.pdc-icon-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 160rpx;
  flex-shrink: 0;
}

.pdc-icon-calendar, .pdc-icon-clock, .pdc-icon-location, .pdc-icon-people, .pdc-icon-key {
  width: 28rpx;
  height: 28rpx;
  background: #2C2C2E;
  mask-size: contain;
  mask-repeat: no-repeat;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
}

