/* skills/party-skill/components/party-create-card/index.wxss */
/* WeCard Design System — Neutral色系 */

.pc-card {
  background: #FFFFFF;
  border: 1px solid #E5E5EA;
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.pc-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  text-align: center;
  margin-bottom: 32rpx;
}

.pc-field {
  margin-bottom: 24rpx;
}

.pc-label {
  display: block;
  font-size: 24rpx;
  color: #6E6E73;
  margin-bottom: 8rpx;
}

.pc-value {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1D1D1F;
  background: #F5F5F7;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.pc-placeholder {
  color: #8E8E93;
}

.pc-btn {
  margin-top: 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #2C2C2E;
  border-radius: 999rpx;
}

.pc-btn-secondary {
  background: #F5F5F7;
  color: #2C2C2E;
}

.pc-btn-hover {
  opacity: 0.85;
}

.pc-success {
  text-align: center;
}

.pc-success-mark {
  width: 96rpx;
  height: 96rpx;
  margin: 16rpx auto 16rpx;
  background: #12B76A;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pc-success-mark-inner {
  width: 32rpx;
  height: 16rpx;
  border-left: 4rpx solid white;
  border-bottom: 4rpx solid white;
  transform: rotate(-45deg);
  margin-bottom: 4rpx;
}

.pc-success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 32rpx;
}

.pc-detail-card {
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.pc-detail-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.pc-detail-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #6E6E73;
  flex-shrink: 0;
}

.pc-detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #1D1D1F;
  min-width: 0;
}

.pc-code {
  font-family: monospace;
  color: #D4813D;
  font-weight: 600;
}

.pc-actions {
  display: flex;
  gap: 24rpx;
}

.pc-actions .pc-btn {
  flex: 1;
  margin-top: 0;
}

@media (prefers-color-scheme: dark) {
  .pc-card { background: #1C1C1E; border-color: rgba(255,255,255,0.08); box-shadow: none; }
  .pc-title, .pc-success-title { color: #FFFFFF; }
  .pc-label { color: rgba(255,255,255,0.68); }
  .pc-value { background: rgba(255,255,255,0.08); color: #FFFFFF; }
  .pc-placeholder { color: rgba(255,255,255,0.48); }
  .pc-detail-card { background: rgba(255,255,255,0.05); }
  .pc-detail-label { color: rgba(255,255,255,0.68); }
  .pc-detail-value { color: #FFFFFF; }
  .pc-code { color: #D4813D; }
  .pc-btn-secondary { background: rgba(255,255,255,0.08); color: #F2F2F7; }
}
